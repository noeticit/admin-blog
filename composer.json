{
    "name": "noeticit/admin-blog",
    "description": "Reusable blog management package for Laravel with Inertia.js, SEO, categories, tags, and AI meta generation",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "laravel",
        "admin",
        "blog",
        "cms",
        "inertia",
        "seo",
        "noetic"
    ],
    "authors": [
        {
            "name": "Noetic IT Services",
            "email": "dev@noetic.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "inertiajs/inertia-laravel": "^1.0|^2.0"
    },
    "suggest": {
        "noeticit/admin-core": "Required for menu registration and permission management"
    },
    "autoload": {
        "psr-4": {
            "Noeticit\\AdminBlog\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Noeticit\\AdminBlog\\BlogServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
